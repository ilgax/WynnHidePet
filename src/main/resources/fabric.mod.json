{
  "schemaVersion": 1,
  "id": "wynnhidepet",
  "version": "${version}",
  "name": "WynnCraft Hide Pets",
  "description": "A kotlin mod for fabric to hide your pets in Wynncraft",
  "authors": [],
  "contact": {
    "homepage": "https://github.com/ilgax/Wynnhidepet",
    "issues": "https://github.com/ilgax/Wynnhidepet/issues"
  },
  "license": "CC-BY-NC-4.0",
  "icon": "icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "dev.ilgax.wynnhidepet.client.WynnhidepetClient"
    ],
    "main": [
      "dev.ilgax.wynnhidepet.Wynnhidepet"
    ],
    "modmenu": [
      "dev.ilgax.wynnhidepet.client.ModMenuIntegration"
    ]
  },
  "mixins": [
    "wynnhidepet.mixins.json",
    {
      "config": "wynnhidepet.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-language-kotlin": ">=${kotlin_loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "cloth-config": ">=21.11.153"
  }
}
